{
  "name": "vidlens-mcp",
  "mcpName": "io.github.rajanrengasamy/vidlens-mcp",
  "version": "1.2.6",
  "description": "VidLens MCP — The YouTube intelligence layer for AI agents. 41 tools, zero config, three-tier fallback, semantic + visual search.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vidlens-mcp": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.map",
    "!dist/test/**",
    "!dist/**/*conflicted copy*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "release:verify": "npm test && npm pack --dry-run",
    "release:publish": "npm test && npm publish --access public",
    "smoke": "node dist/scripts/smoke.js",
    "smoke:dry": "node dist/scripts/smoke.js --dry-run"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "youtube",
    "youtube-api",
    "youtube-transcript",
    "video-intelligence",
    "video-analysis",
    "model-context-protocol",
    "yt-dlp",
    "semantic-search",
    "sentiment-analysis"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "execa": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
